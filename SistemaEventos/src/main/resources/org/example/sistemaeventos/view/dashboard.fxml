<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="550.0" prefWidth="900.0" stylesheets="@../styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.sistemaeventos.controller.DashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15">
            <padding>
                <Insets bottom="10" left="15" right="15" top="15" />
            </padding>
            <Label styleClass="label-titulo" text="Sistema de Eventos" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblUsuarioActivo" style="-fx-font-weight: bold;" text="-" />
            <Label fx:id="lblRolActivo" text="-" />
            <Button fx:id="btnReservas" onAction="#irAReservas" text="Reservas" />
            <Button onAction="#cerrarSesion" styleClass="button-salir" text="Cerrar sesión" />
        </HBox>
    </top>

    <left>
        <VBox prefWidth="260" spacing="10">

            <VBox fx:id="panelFormulario" spacing="10" styleClass="panel-formulario">
                <padding>
                    <Insets bottom="15" left="15" right="15" top="15" />
                </padding>

                <Label styleClass="label-subtitulo" text="Registrar / Editar Evento" />

                <Label text="Nombre de evento" />
                <TextField fx:id="txtNombre" />

                <Label text="Tipo de evento" />
                <TextField fx:id="txtTipo" />

                <Label text="Horario inicio" />
                <TextField fx:id="txtInicio" />

                <Label text="Horario fin" />
                <TextField fx:id="txtFin" />

                <Label text="Fecha" />
                <DatePicker fx:id="dpFecha" />

                <HBox spacing="10">
                    <Button onAction="#registrar" text="Registrar" />
                    <Button onAction="#actualizar" text="Actualizar" />
                    <Button onAction="#eliminar" styleClass="button-cancelar" text="Eliminar" />
                </HBox>
            </VBox>

            <VBox fx:id="panelResumen" spacing="10" styleClass="panel-resumen">
                <padding>
                    <Insets bottom="15" left="15" right="15" top="15" />
                </padding>

                <Label styleClass="label-subtitulo" text="Resumen de Eventos" />

                <Label text="Total de eventos:" />
                <Label fx:id="lblTotalEventos" style="-fx-font-weight: bold;" text="0" />

                <Label text="Pendientes:" />
                <Label fx:id="lblPendientes" style="-fx-font-weight: bold;" text="0" />

                <Label text="Confirmados:" />
                <Label fx:id="lblConfirmados" style="-fx-font-weight: bold;" text="0" />

                <Label text="Cancelados:" />
                <Label fx:id="lblCancelados" style="-fx-font-weight: bold;" text="0" />
            </VBox>

        </VBox>
    </left>

    <center>
        <TableView fx:id="tblEventos" prefHeight="400.0">
            <columns>
                <TableColumn fx:id="colNombre" prefWidth="140" text="Nombre" />
                <TableColumn fx:id="colTipo" prefWidth="90" text="Tipo" />
                <TableColumn fx:id="colInicio" prefWidth="80" text="Inicio" />
                <TableColumn fx:id="colFin" prefWidth="80" text="Fin" />
                <TableColumn fx:id="colFecha" prefWidth="90" text="Fecha" />
                <TableColumn fx:id="colEstado" prefWidth="100" text="Estado" />
            </columns>
            <BorderPane.margin>
                <Insets left="15" right="15" />
            </BorderPane.margin>
        </TableView>
    </center>

    <right>
        <VBox fx:id="panelDetalle" prefWidth="250" spacing="10">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>

            <Label styleClass="label-subtitulo" text="Detalle del Evento" />
            <Button onAction="#verDetalle" text="Ver Detalle" />

            <Label style="-fx-font-weight: bold;" text="Nombre:" />
            <Label fx:id="lblNombre" text="-" wrapText="true" />

            <Label style="-fx-font-weight: bold;" text="Tipo:" />
            <Label fx:id="lblTipo" text="-" />

            <Label style="-fx-font-weight: bold;" text="Hora inicio:" />
            <Label fx:id="lblInicio" text="-" />

            <Label style="-fx-font-weight: bold;" text="Hora fin:" />
            <Label fx:id="lblFin" text="-" />

            <Label style="-fx-font-weight: bold;" text="Fecha:" />
            <Label fx:id="lblFecha" text="-" />

            <Label style="-fx-font-weight: bold;" text="Estado:" />
            <Label fx:id="lblEstado" text="-" />

            <HBox fx:id="panelAcciones" spacing="10">
                <Button onAction="#confirmarEvento" styleClass="button-confirmar" text="Confirmar" />
                <Button onAction="#cancelarEvento" styleClass="button-cancelar" text="Cancelar" />
            </HBox>
        </VBox>
    </right>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <padding>
                <Insets bottom="15" left="15" right="15" top="10" />
            </padding>
            <Button onAction="#actualizarLista" text="Actualizar lista" />
        </HBox>
    </bottom>

</BorderPane>